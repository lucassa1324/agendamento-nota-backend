{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "bun dev",
  "installCommand": "bun install",
  "functions": {
    "api/index.ts": {
      "runtime": "bun@1.x",
      "includeFiles": [
        "node_modules/@better-auth/telemetry/**/*"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ]
}